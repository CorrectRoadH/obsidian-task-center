# US-601: release tags must match `[0-9]+.[0-9]+.[0-9]+` (no `v` prefix).
# `pnpm version` follows npm-compatible version config; force the prefix off so `pnpm version
# minor` produces tag `0.2.0` (not `v0.2.0`) and the release.yml workflow
# triggers without manual `git tag -d v…` cleanup.
tag-version-prefix=
