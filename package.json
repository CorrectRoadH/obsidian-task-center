{
  "name": "obsidian-task-center",
  "version": "0.2.6",
  "description": "Task board + CLI for energy-based task management on top of Obsidian Tasks syntax",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --test test/parser.test.mjs test/writer.test.mjs test/cli.test.mjs test/quickadd.test.mjs test/cache.test.mjs test/i18n.test.mjs",
    "test:e2e": "npm run build && wdio run ./wdio.conf.mts",
    "lint": "eslint src",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "tasks",
    "kanban",
    "energy-management"
  ],
  "author": "ctrdh",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "builtin-modules": "^3.3.0",
    "chai": "^6.2.2",
    "esbuild": "^0.21.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "mocha": "^11.7.5",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.0",
    "wdio-obsidian-reporter": "^3.0.2",
    "wdio-obsidian-service": "^3.0.2"
  }
}
